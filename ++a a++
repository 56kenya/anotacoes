considerando

int a;
int b;

a = 1;
b = ++a;

++a = primeiro soma depois atribui, portanto:  a = 2   b = 1

-----------------------------------------------

contriariamente

int a;
int b;

a = 1;
b = a++;

a++ = primeiro soma depois atribui, portanto:  a = 2   b = 2


